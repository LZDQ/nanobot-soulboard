# Domain and path prefix for backend API/WebSocket calls.
# "" -> <injected-base>/api/..., "/prefix" -> /prefix/api/..., "http://example.com/aaa" -> http://example.com/aaa/api/...
# Leave empty (or unset) for production; the backend-injected <base href> supplies the mount prefix.
VITE_API_BASE=http://127.0.0.1:18792
